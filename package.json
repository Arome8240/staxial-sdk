{
  "name": "staxial-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for interacting with Staxial Health contracts on the Stacks blockchain",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:utils": "vitest run tests/utils.test.ts",
    "test:contract": "vitest run tests/contract.test.ts",
    "test:constants": "vitest run tests/constants.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "keywords": [
    "stacks",
    "blockchain",
    "bitcoin",
    "stx",
    "sdk",
    "staxial",
    "health",
    "healthcare",
    "medical",
    "clarity",
    "web3"
  ],
  "author": "Staxial",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arome8240/staxial-sdk"
  },
  "bugs": {
    "url": "https://github.com/arome8240/staxial-sdk/issues"
  },
  "homepage": "https://github.com/arome8240/staxial-sdk#readme",
  "dependencies": {
    "@stacks/transactions": "^6.12.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
